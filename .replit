modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5050
externalPort = 4200

[[ports]]
localPort = 5051
externalPort = 3000

[[ports]]
localPort = 5060
externalPort = 3002

[[ports]]
localPort = 5099
externalPort = 6000

[[ports]]
localPort = 23636
externalPort = 80

[[ports]]
localPort = 23637
externalPort = 3001

[[ports]]
localPort = 23638
externalPort = 3003

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
publicDir = "dist/public"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:shared-inbox"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "guardrails"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "storage-integration"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:freight-capture-funnel"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:lane-system-e2e"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "test:shared-inbox"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx tests/shared-inbox-webhook-e2e.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run check"

[[workflows.workflow]]
name = "guardrails"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx tests/code-quality-guardrails.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "storage-integration"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx tests/storage-integration.test.ts"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test:freight-capture-funnel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx tests/freight-capture-funnel.test.ts"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test:lane-system-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx playwright test --config=playwright.config.cjs tests/lane-system-e2e.spec.cjs --workers=4"

[workflows.workflow.metadata]
isValidation = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[agent]
integrations = ["javascript_openai_ai_integrations:2.0.0", "javascript_anthropic_ai_integrations:2.0.0", "stripe:1.0.0"]

[userenv]

[userenv.shared]
SMTP_HOST = "smtpout.secureserver.net"
SMTP_PORT = "465"
SMTP_FROM = "info@freight-dna.com"
SMTP_FROM_NAME = "Value Truck · Growth Chart"
OUTLOOK_REPLY_EMAIL = "Ops@valuetruck.com"

[userenv.development]
DEV_AUTH_BYPASS_USER_ID = "4e75fd7c-d462-42c5-a335-af327076416c"
VITE_DEV_AUTH_BYPASS = "true"
